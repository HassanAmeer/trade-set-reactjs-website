  <script>
    // Mobile menu toggle
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('navLinks');
    hamburger.addEventListener('click', () => navLinks.classList.toggle('show'));

    // Scroll reveal
    const revealElements = document.querySelectorAll('.section');
    const onScroll = () => {
      const vh = window.innerHeight;
      revealElements.forEach(el => {
        const rect = el.getBoundingClientRect();
        if (rect.top < vh - 100) {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }
      });
    };
    window.addEventListener('scroll', onScroll);
    revealElements.forEach(el => { el.style.opacity='0'; el.style.transform='translateY(40px)'; el.style.transition='opacity .6s, transform .6s'; });

    // Counter animation
    const counters = document.querySelectorAll('.stat h3');
    const animateCounters = () => {
      counters.forEach(counter => {
        const target = +counter.textContent.replace(/[^0-9]/g,'');
        let count = 0;
        const inc = Math.ceil(target/120);
        const update = () => {
          count += inc;
          if (count > target) count = target;
          const s = counter.querySelector('span').innerHTML;
          counter.innerHTML = count + '<span>' + s + '</span>';
          if (count < target) requestAnimationFrame(update);
        };
        update();
      });
    };
    const statsSection = document.querySelector('.hero-stats');
    const statsObs = new IntersectionObserver(entries=>{ if(entries[0].isIntersecting){ animateCounters(); statsObs.unobserve(statsSection); } }, {threshold:0.5});
    statsObs.observe(statsSection);

    // Typewriter effect
    const tBody = document.getElementById('terminalBody');
    const cmds = [
      {text: 'cheap "create a landing page with React"', delay:500},
      {text: '✔ Generated Landing.jsx', output:true},
      {text: '✔ Generated Landing.css', output:true},
      {text: 'cheap "add dark mode toggle"', delay:800},
      {text: '✔ Updated theme files', output:true}
    ];
    let ci = 0;
    function typeCmd(c){
      const line = document.createElement('div');
      line.className = 'line';
      tBody.appendChild(line);
      if(c.output){
        line.textContent = c.text;
        setTimeout(nextCmd, 800);
        return;
      }
      const p = document.createElement('span');
      p.textContent = '❯ ';
      p.style.color = '#D48148';
      line.appendChild(p);
      const sp = document.createElement('span');
      sp.style.color = '#FFF1E8';
      line.appendChild(sp);
      let i = 0;
      const t = setInterval(()=>{
        if(i < c.text.length){
          sp.textContent += c.text.charAt(i);
          i++;
        } else {
          clearInterval(t);
          const cur = document.createElement('span');
          cur.className = 'cursor';
          line.appendChild(cur);
          setTimeout(nextCmd, c.delay || 1200);
        }
      }, 40);
    }
    function nextCmd(){
      if(ci < cmds.length){
        typeCmd(cmds[ci]);
        ci++;
      }
    }
    nextCmd();

    // FAQ accordion
    document.querySelectorAll('.faq .question').forEach(q=>{
      q.addEventListener('click',()=>{
        q.classList.toggle('active');
        const ans = q.nextElementSibling;
        ans.style.maxHeight = q.classList.contains('active') ? ans.scrollHeight + 'px' : '0';
      });
    });

    // Particle background
    const cvs = document.createElement('canvas');
    const ctx = cvs.getContext('2d');
    const hbg = document.getElementById('heroBg');
    hbg.appendChild(cvs);
    let pts = [];
    const initPts = () => {
      cvs.width = window.innerWidth;
      cvs.height = window.innerHeight;
      pts = [];
      for(let i=0;i<80;i++){
        pts.push({x:Math.random()*cvs.width, y:Math.random()*cvs.height, r:Math.random()*2+0.5, vx:(Math.random()-0.5)*0.4, vy:(Math.random()-0.5)*0.4});
      }
    };
    const drawPts = () => {
      ctx.clearRect(0,0,cvs.width,cvs.height);
      ctx.fillStyle = 'rgba(212,129,72,0.12)';
      pts.forEach(p=>{
        ctx.beginPath();
        ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
        ctx.fill();
        p.x+=p.vx; p.y+=p.vy;
        if(p.x<0||p.x>cvs.width) p.vx*=-1;
        if(p.y<0||p.y>cvs.height) p.vy*=-1;
      });
      requestAnimationFrame(drawPts);
    };
    initPts();
    drawPts();
    window.addEventListener('resize', initPts);

    // Testimonial rotation
    const tms = document.querySelectorAll('.testimonial');
    let tc = 0;
    setInterval(()=>{
      tms[tc].classList.remove('active');
      tc = (tc+1)%tms.length;
      tms[tc].classList.add('active');
    }, 6000);
  </script>
</body>
</html>