      .hero-content { grid-template-columns:1fr; text-align:center; }
      .hero-right { margin:0 auto; }
    }
    @media (max-width:768px) {
      .nav-links { flex-direction:column; }
      .hero h1 { font-size:2.5rem; }
      .section-title { font-size:2.2rem; }
    }
  </style>
</head>
