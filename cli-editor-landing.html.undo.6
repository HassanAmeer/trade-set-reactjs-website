<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CHEAP — AI‑Powered CLI Code Editor</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ─── Design Tokens ─── */
    :root {
      --bg: #0B0806;
      --primary: #D48148;
      --primary-light: #f0a070;
      --heading: #FFF1E8;
      --muted: #A89F98;
      --surface: #18110C;
      --border: #2D211A;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior:smooth; }
    body {
      font-family:'Inter',sans-serif;
      background:var(--bg);
      color:var(--heading);
      overflow-x:hidden;
    }
    a { text-decoration:none; color:inherit; }
    .container { max-width:1200px; margin:0 auto; padding:0 24px; }

    /* ─── Utilities ─── */
    .flex { display:flex; align-items:center; }
    .justify-between { justify-content:space-between; }
    .grid { display:grid; gap:24px; }
    .text-center { text-align:center; }
    .btn { cursor:pointer; border:none; border-radius:8px; padding:12px 24px; font-weight:600; transition:transform .2s,box-shadow .2s; }
    .btn-primary { background:linear-gradient(135deg,var(--primary),#b86a3a); color:var(--heading); }
    .btn-primary:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(212,129,72,.3); }
    .btn-outline { background:transparent; border:1px solid rgba(255,241,232,.12); color:var(--heading); }
    .btn-outline:hover { background:rgba(255,241,232,.04); }
    .section { padding:80px 0; position:relative; }
    .section-label { font-family:'JetBrains Mono',monospace; font-size:0.8rem; color:var(--primary); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:12px; }
    .section-title { font-size:2.8rem; font-weight:700; margin-bottom:16px; line-height:1.2; }
    .section-sub { max-width:600px; margin:0 auto 40px; color:var(--muted); font-size:1.05rem; line-height:1.7; }

    /* ─── Navbar ─── */
    .navbar {
      position:fixed; top:0; left:0; right:0; z-index:1000; padding:16px 0;
      background:rgba(11,8,6,.7); backdrop-filter:blur(12px); border-bottom:1px solid rgba(255,241,232,.06);
    }
    .nav-logo { font-family:'JetBrains Mono',monospace; font-weight:700; font-size:1.3rem; color:var(--heading); }
    .nav-logo span { color:var(--primary); }
    .nav-links { display:flex; gap:24px; }
    .nav-links a { font-size:0.9rem; color:var(--muted); transition:color .2s; }
    .nav-links a:hover { color:var(--heading); }
    .nav-cta { background:linear-gradient(135deg,var(--primary),#b86a3a); color:var(--heading) !important; padding:8px 20px; border-radius:6px; }
    .hamburger { display:none; flex-direction:column; gap:4px; cursor:pointer; }
    .hamburger div { width:20px; height:2px; background:var(--heading); }
    @media (max-width:768px) {
      .nav-links { display:none; flex-direction:column; background:rgba(11,8,6,.9); position:absolute; top:100%; left:0; right:0; padding:12px 0; }
      .nav-links.show { display:flex; }
      .hamburger { display:flex; }
    }

    /* ─── Hero ─── */
    .hero { min-height:100vh; display:flex; align-items:center; padding-top:80px; overflow:hidden; }
    .hero-bg { position:absolute; inset:0; overflow:hidden; pointer-events:none; }
    .hero-bg canvas { width:100%; height:100%; display:block; }
    .hero-content { position:relative; z-index:2; display:grid; grid-template-columns:1fr 1fr; gap:48px; align-items:center; }
    .hero-left { display:flex; flex-direction:column; gap:20px; }
    .hero-badge { display:inline-flex; align-items:center; gap:8px; padding:6px 12px; border-radius:999px; background:rgba(212,129,72,.1); border:1px solid rgba(212,129,72,.2); font-size:0.8rem; color:var(--primary-light); }
    .hero-badge .dot { width:6px; height:6px; border-radius:50%; background:#22c55e; animation:pulse .8s infinite; }
    @keyframes pulse { 0%,100%{opacity:1;}50%{opacity:.4;} }
    .hero h1 { font-size:3.5rem; font-weight:800; line-height:1.1; }
    .hero h1 .gradient { background:linear-gradient(135deg,var(--heading),var(--primary-light),var(--primary)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .hero p { font-size:1.1rem; color:var(--muted); max-width:480px; line-height:1.7; }
    .hero-ctas { display:flex; gap:12px; margin-top:8px; }
    .hero-stats { display:flex; gap:24px; margin-top:12px; }
    .stat { text-align:center; }
    .stat h3 { font-size:1.8rem; color:var(--heading); }
    .stat h3 span { color:var(--primary); }
    .stat p { font-size:0.8rem; color:var(--muted); margin-top:4px; }
    .terminal-mock { position:relative; width:100%; max-width:500px; }
    .terminal-window { background:#050302; border-radius:12px; border:1px solid rgba(255,241,232,.08); overflow:hidden; box-shadow:0 20px 50px rgba(0,0,0,.5); }
    .terminal-header { display:flex; align-items:center; gap:8px; padding:8px 12px; background:rgba(255,241,232,.03); border-bottom:1px solid rgba(255,241,232,.06); }
    .dot { width:10px; height:10px; border-radius:50%; }
    .dot.red{background:#ff5f56;} .dot.yellow{background:#ffbd2e;} .dot.green{background:#27c93f;}
    .terminal-title { font-family:'JetBrains Mono',monospace; font-size:0.7rem; color:var(--muted); }
    .terminal-body { padding:16px; font-family:'JetBrains Mono',monospace; font-size:0.85rem; line-height:1.6; color:#c4b5a5; min-height:260px; }
    .line { opacity:0; animation:fade .4s forwards; }
    .line:nth-child(1){animation-delay:.3s;}
    .line:nth-child(2){animation-delay:1s;}
    .line:nth-child(3){animation-delay:1.8s;}
    .line:nth-child(4){animation-delay:2.6s;}
    .line:nth-child(5){animation-delay:3.4s;}
    @keyframes fade { to { opacity:1; } }
    .cursor { display:inline-block; width:8px; height:16px; background:var(--primary); animation:blink 1s steps(2) infinite; margin-left:4px; }
    @keyframes blink {0%,100%{opacity:1;}50%{opacity:0;}}

    /* ─── Trust Bar ─── */
    .trust { background:var(--surface); padding:24px 0; }
    .trust .logos { display:flex; justify-content:center; gap:40px; flex-wrap:wrap; }
    .trust img { height:32px; filter:brightness(.8) contrast(1.2); }

    /* ─── Features ─── */
    .features .grid { grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); }
    .feature-card { background:rgba(24,17,12,.6); border:1px solid rgba(255,241,232,.06); border-radius:12px; padding:24px; transition:transform .3s,border-color .3s; }
    .feature-card:hover { transform:translateY(-4px); border-color:var(--primary); }
    .feature-icon { font-size:1.8rem; margin-bottom:12px; color:var(--primary); }
    .feature-card h3 { font-size:1.2rem; margin-bottom:8px; }
    .feature-card p { color:var(--muted); font-size:0.9rem; line-height:1.5; }

    /* ─── How It Works ─── */
    .how .step { display:flex; align-items:flex-start; gap:16px; }
    .how .step-number { width:36px; height:36px; border-radius:50%; background:var(--primary); color:var(--heading); display:flex; align-items:center; justify-content:center; font-weight:600; }
    .how .step-content h4 { font-size:1.3rem; margin-bottom:6px; }
    .how .step-content p { color:var(--muted); font-size:0.95rem; }

    /* ─── Integrations ─── */
    .integrations .grid { grid-template-columns:repeat(auto-fit,minmax(120px,1fr)); justify-items:center; }
    .integrations img { height:40px; filter:brightness(.9); }

    /* ─── Pricing ─── */
    .pricing .grid { grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:32px; }
    .price-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:32px; text-align:center; transition:transform .3s,box-shadow .3s; }
    .price-card:hover { transform:translateY(-6px); box-shadow:0 12px 30px rgba(0,0,0,.4); }
    .price-card h3 { font-size:1.8rem; margin-bottom:8px; }
    .price-card .price { font-size:2.2rem; font-weight:700; margin:12px 0; color:var(--primary); }
    .price-card ul { text-align:left; margin:16px 0; color:var(--muted); }
    .price-card li { margin-bottom:8px; }

    /* ─── Testimonials ─── */
    .testimonials { position:relative; }
    .testimonial { opacity:0; transition:opacity .5s; text-align:center; max-width:600px; margin:0 auto; }
    .testimonial.active { opacity:1; }
    .testimonial img { width:80px; height:80px; border-radius:50%; margin-bottom:12px; }
    .testimonial p { font-style:italic; color:var(--muted); margin-bottom:12px; }
    .testimonial h4 { font-weight:600; color:var(--heading); }

    /* ─── FAQ ─── */
    .faq .question { cursor:pointer; padding:12px; border-bottom:1px solid var(--border); }
    .faq .answer { max-height:0; overflow:hidden; transition:max-height .3s ease; padding:0 12px; color:var(--muted); }
    .faq .question.active + .answer { max-height:200px; padding-top:8px; }

    /* ─── Final CTA ─── */
    .final-cta { background:linear-gradient(135deg,var(--primary),#b86a3a); color:var(--heading); text-align:center; padding:80px 0; border-radius:12px; }
    .final-cta h2 { font-size:2.5rem; margin-bottom:20px; }

    /* ─── Footer ─── */
    .footer { background:var(--surface); padding:40px 0; border-top:1px solid var(--border); }
    .footer .grid { grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:24px; }
    .footer a { color:var(--muted); font-size:0.9rem; transition:color .2s; }
    .footer a:hover { color:var(--heading); }
    .footer .logo { font-family:'JetBrains Mono',monospace; font-size:1.2rem; color:var(--primary); }

    /* ─── Responsive ─── */
